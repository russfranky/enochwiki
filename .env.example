# Copy to .env and fill in. NEVER commit the real .env.

# Required — Prisma/SQLite connection. Use a path that exists on your machine.
DATABASE_URL="file:./db/custom.db"

# Optional — Z.ai API (AI study companion, web search, page reader, summarize).
# Without a key the app degrades gracefully to free fallbacks.
# Get one at https://z.ai/ — keep it secret, never hardcode it in source.
ZAI_API_KEY=""

# Optional overrides (defaults shown).
# ZAI_BASE_URL="https://api.z.ai/api/paas/v4"
# ZAI_MODEL="glm-4.5"

# Semantic RAG embeddings (optional — keyword/FTS RAG works without this).
# Any OpenAI-compatible /embeddings endpoint. Ollama (local, free): pull nomic-embed-text.
EMBED_BASE_URL=""   # e.g. http://localhost:11434/v1
EMBED_MODEL=""      # e.g. nomic-embed-text | text-embedding-3-small
EMBED_API_KEY=""    # optional (Ollama/LM Studio need none)
