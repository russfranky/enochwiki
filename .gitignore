# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
# Agent tooling under .claude IS tracked (workflows + skills); keep only private/local bits out
.claude/settings.local.json
.claude/*.local.json
.z-ai-config
*.log
dev.log
dev.out.log
.grow.lock
test
prompt

server.log
# Skills directory
/skills/

# SQLite database — regenerate via `prisma db push` + seed scripts; never commit the blob
db/
*.db
*.db-journal

# Generated/large assets and agent caches — not part of the foundational repo
/download/
/tool-results/
/outputs/
# npm lockfile — this project uses bun (bun.lock)
package-lock.json
